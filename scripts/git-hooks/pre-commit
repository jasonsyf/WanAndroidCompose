#!/bin/bash
echo "--- Running pre-commit hook ---"

# 1. 代码格式检查 (ktlint)
echo "🔍 检查代码格式 (ktlint)..."
./gradlew ktlintCheck --quiet
if [ $? -ne 0 ]; then
    echo "❌ ktlint 检查失败！请先运行 ./gradlew ktlintFormat 修复格式。"
    exit 1
fi

# 2. 大图资源拦截 (> 200KB)
echo "🔍 检查新增大图资源 (> 200KB)..."
# 仅检查新添加(A)或修改(M)的文件
STAGED_IMAGES=$(git diff --cached --name-only --diff-filter=AM | grep -E "\.(png|jpg|jpeg|webp)$")
if [ ! -z "$STAGED_IMAGES" ]; then
    for img in $STAGED_IMAGES; do
        if [ -f "$img" ]; then
            # macOS 下 du -k 输出格式略有不同，这里做通用处理
            size=$(du -k "$img" | cut -f1)
            if [ $size -gt 200 ]; then
                echo "❌ 发现超大图片资源: $img (${size}KB)。请压缩至 200KB 以下后再提交。"
                exit 1
            fi
        fi
    done
fi

# 3. 调试日志与敏感关键字检查
echo "🔍 检查调试日志..."
# 检查 println 和 Log.d/v 等，排除测试文件
STAGED_KT_FILES=$(git diff --cached --name-only --diff-filter=AM | grep ".kt$")
if [ ! -z "$STAGED_KT_FILES" ]; then
    LOG_USAGE=$(echo "$STAGED_KT_FILES" | xargs grep -E "println\(|Log\.[dv]\(" | grep -v "Test.kt")
    if [ ! -z "$LOG_USAGE" ]; then
        echo "⚠️ 发现代码中包含调试日志或 println："
        echo "$LOG_USAGE"
        echo "建议移除后再提交，以保持线上日志整洁。"
        # 这里设置为警告，不强制中断
    fi
fi

echo "✅ pre-commit 检查通过！"
exit 0
