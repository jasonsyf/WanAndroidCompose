#!/bin/bash
# =================================================================================
# Git pre-push 钩子 (变动感知版)
# =================================================================================
# 触发时机：执行 git push 之前
# 设计思路：识别本地与远程分支的差异，仅在涉及核心逻辑或 UI 时才运行重度测试任务。

echo "--- 🚀 正在执行推送前深度验证 (Pre-push Hook) ---"

# 1. 识别变动范围
# 比较当前分支 HEAD 与上游分支（如果不存在则对比 master）
REMOTE_BRANCH=$(git rev-parse --abbrev-ref --symbolic-full-name @{u} 2>/dev/null || echo "master")
CHANGED_FILES=$(git diff --name-only $REMOTE_BRANCH...HEAD)

if [ -z "$CHANGED_FILES" ]; then
    echo "✨ 没有检测到待推送的变动，跳过验证。"
    exit 0
fi

# 2. 增量单元测试 (Unit Tests)
# 只要涉及 Kotlin 代码修改，就运行单元测试以防逻辑回归。
if echo "$CHANGED_FILES" | grep -qE "\.kt$|\.kts$"; then
    echo "🔍 [1/3] 正在运行单元测试 (Unit Tests)..."
    ./gradlew :app:testDebugUnitTest --quiet
    if [ $? -ne 0 ]; then
        echo "❌ 单元测试未通过！推送已被拦截，请先修复测试。"
        exit 1
    fi
else
    echo "✨ [1/3] 未涉及代码变动，跳过单元测试。"
fi

# 3. 增量静态扫描 (Android Lint)
# 针对关键资源或配置文件的变动运行 Lint。
if echo "$CHANGED_FILES" | grep -qE "app/src/main/|app/src/release/|build\.gradle"; then
    echo "🔍 [2/3] 正在运行 Android Lint 扫描..."
    ./gradlew lintDebug --quiet
    if [ $? -ne 0 ]; then
        echo "❌ Lint 检查发现严重问题！请修复后再推送。"
        exit 1
    fi
else
    echo "✨ [2/3] 未涉及核心资源变动，跳过 Lint 扫描。"
fi

# 4. 增量截图测试 (Visual Regression)
# 当修改 UI 组件（View.kt）、主题（Theme.kt）或资源文件时，触发 Paparazzi 校验。
if echo "$CHANGED_FILES" | grep -qE "View\.kt$|Theme\.kt$|Color\.kt$|res/|drawable/"; then
    echo "🔍 [3/3] 正在验证 UI 视觉一致性 (Paparazzi)..."
    ./gradlew verifyPaparazziDebug --quiet
    if [ $? -ne 0 ]; then
        echo "❌ 发现 UI 视觉回归问题！"
        echo "💡 提示：请运行 ./gradlew recordPaparazziDebug 查看差异。您也可以使用 'android layout -p' 实时分析当前页面布局。"
        exit 1
    fi
else
    echo "✨ [3/3] 未涉及 UI 变动，跳过截图测试。"
fi

echo "✅ 所有深度验证通过！允许推送。"
exit 0
