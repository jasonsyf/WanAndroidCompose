#!/bin/bash
echo "--- Running pre-push hook ---"

# 1. 单元测试
echo "🔍 运行单元测试..."
./gradlew :app:testDebugUnitTest --quiet
if [ $? -ne 0 ]; then
    echo "❌ 单元测试失败！推送已被拦截。请先修复测试。"
    exit 1
fi

# 2. UI 截屏回归测试 (Paparazzi)
echo "🔍 验证 UI 截屏 (Paparazzi)..."
# 使用 verify 任务对比基准图，确保没有视觉回归
./gradlew verifyPaparazziDebug --quiet
if [ $? -ne 0 ]; then
    echo "❌ UI 截屏测试未通过！发现视觉回归问题。"
    echo "请运行 ./gradlew recordPaparazziDebug 查看差异并更新基准图。"
    exit 1
fi

echo "✅ pre-push 验证通过！允许推送。"
exit 0
